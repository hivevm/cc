RULE identifier() : Token ::=
  <? Token t; ?>
  t=<IDENTIFIER>
  <? return t; ?>
};

RULE value() : Token ::=
  ( <INTEGER_LITERAL> | <FALSE> | <TRUE> )
  <? return token; ?>
};

